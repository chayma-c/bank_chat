# ══════════════════════════════════════════════════════════════════════════
# VARIABLES D'ENVIRONNEMENT — Backend & Services
# ══════════════════════════════════════════════════════════════════════════
# Ce fichier doit être placé dans : ./backend/.env
# ══════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────
# 🗄️ BASE DE DONNÉES ORCHESTRATEUR
# ──────────────────────────────────────────────────────────────────────────
DB_HOST=db
DB_NAME=bank_orchestrateur
DB_USER=orchestrateur_user
DB_PASSWORD=orchestrateur_password
DB_PORT=5432

# ──────────────────────────────────────────────────────────────────────────
# 🔴 REDIS
# ──────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ──────────────────────────────────────────────────────────────────────────
# 🔐 KEYCLOAK
# ──────────────────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080/auth
KEYCLOAK_REALM=myrealm
KEYCLOAK_CLIENT_ID=bank_chat
KEYCLOAK_CLIENT_SECRET=your-client-secret-here

# ──────────────────────────────────────────────────────────────────────────
# 🚨 FRAUD SERVICE
# ──────────────────────────────────────────────────────────────────────────
FRAUD_SERVICE_URL=http://fraud-service:8001

# ──────────────────────────────────────────────────────────────────────────
# 🤖 LLM PROVIDER (Ollama / OpenAI / Anthropic)
# ──────────────────────────────────────────────────────────────────────────
# Options : ollama | openai | anthropic
LLM_PROVIDER=ollama

# Pour Ollama (local)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# Pour OpenAI (si LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4

# Pour Anthropic (si LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ──────────────────────────────────────────────────────────────────────────
# 🔧 DJANGO SETTINGS
# ──────────────────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,orchestrateur,api-gateway

# ──────────────────────────────────────────────────────────────────────────
# 📊 LOGGING & MONITORING
# ──────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_SQL_LOGGING=False

# ──────────────────────────────────────────────────────────────────────────
# 🌐 CORS (si nécessaire)
# ──────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost

# ──────────────────────────────────────────────────────────────────────────
